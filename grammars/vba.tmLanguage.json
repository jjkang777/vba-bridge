{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VBA",
  "scopeName": "source.vba",
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#procedure-declaration" },
    { "include": "#property-declaration" },
    { "include": "#variable-declaration" },
    { "include": "#option-statements" },
    { "include": "#on-error" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#storage-modifiers" },
    { "include": "#data-types" },
    { "include": "#control-keywords" },
    { "include": "#other-keywords" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.apostrophe.vba",
          "match": "(').*$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.vba" }
          }
        },
        {
          "name": "comment.line.rem.vba",
          "match": "(?i)^\\s*(Rem)\\b.*$",
          "captures": {
            "1": { "name": "keyword.other.rem.vba" }
          }
        },
        {
          "name": "comment.line.rem.vba",
          "match": "(?i)(?<=:)\\s*(Rem)\\b.*$",
          "captures": {
            "1": { "name": "keyword.other.rem.vba" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vba",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.vba" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.vba" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.vba",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.vba",
          "match": "(?i)&H[0-9A-F]+[&%^]?"
        },
        {
          "name": "constant.numeric.octal.vba",
          "match": "(?i)&O[0-7]+[&%^]?"
        },
        {
          "name": "constant.numeric.float.vba",
          "match": "(?i)\\b\\d+\\.\\d*([ED][+-]?\\d+)?[!#@]?\\b"
        },
        {
          "name": "constant.numeric.float.vba",
          "match": "(?i)\\b\\d*\\.\\d+([ED][+-]?\\d+)?[!#@]?\\b"
        },
        {
          "name": "constant.numeric.float.vba",
          "match": "(?i)\\b\\d+[ED][+-]?\\d+[!#@]?\\b"
        },
        {
          "name": "constant.numeric.integer.vba",
          "match": "\\b\\d+[%&^!#@$]?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vba",
          "match": "(?i)\\b(True|False)\\b"
        },
        {
          "name": "constant.language.vba",
          "match": "(?i)\\b(Nothing|Empty|Null)\\b"
        },
        {
          "name": "constant.language.vb.vba",
          "match": "(?i)\\b(vbCrLf|vbCr|vbLf|vbNewLine|vbNullChar|vbNullString|vbTab|vbBack|vbFormFeed|vbVerticalTab|vbObjectError|vbAbort|vbCancel|vbIgnore|vbNo|vbOK|vbRetry|vbYes|vbAbortRetryIgnore|vbApplicationModal|vbCritical|vbDefaultButton1|vbDefaultButton2|vbDefaultButton3|vbDefaultButton4|vbExclamation|vbInformation|vbMsgBoxHelpButton|vbMsgBoxRight|vbMsgBoxRtlReading|vbMsgBoxSetForeground|vbOKCancel|vbOKOnly|vbQuestion|vbRetryCancel|vbSystemModal|vbYesNo|vbYesNoCancel|vbBlack|vbBlue|vbCyan|vbGreen|vbMagenta|vbRed|vbWhite|vbYellow|vbBinaryCompare|vbDatabaseCompare|vbTextCompare|vbArray|vbBoolean|vbByte|vbCurrency|vbDataObject|vbDate|vbDecimal|vbDouble|vbEmpty|vbError|vbInteger|vbLong|vbNull|vbObject|vbSingle|vbString|vbUserDefinedType|vbVariant)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.vba",
          "match": "<>|<=|>=|<|>|="
        },
        {
          "name": "keyword.operator.arithmetic.vba",
          "match": "\\+|-|\\*|/|\\\\|\\^"
        },
        {
          "name": "keyword.operator.concatenation.vba",
          "match": "&"
        },
        {
          "name": "keyword.operator.logical.vba",
          "match": "(?i)\\b(And|Or|Not|Xor|Eqv|Imp)\\b"
        },
        {
          "name": "keyword.operator.comparison.vba",
          "match": "(?i)\\b(Is|Like)\\b"
        },
        {
          "name": "keyword.operator.arithmetic.vba",
          "match": "(?i)\\b(Mod)\\b"
        },
        {
          "name": "keyword.operator.assignment.vba",
          "match": ":="
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(If|Then|Else|ElseIf|End\\s+If)\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(For|To|Step|Next|Each|In)\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(Do|Loop|While|Wend|Until)\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(Select\\s+Case|Case|End\\s+Select)\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(With|End\\s+With)\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(GoTo|GoSub|Return)\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(Exit\\s+(Sub|Function|Property|For|Do))\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\b(End\\s+(Sub|Function|Property|Type|Enum))\\b"
        },
        {
          "name": "keyword.control.vba",
          "match": "(?i)\\bEnd\\b"
        }
      ]
    },
    "other-keywords": {
      "patterns": [
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Set|Let|Call)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Resume|Resume\\s+Next)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Implements)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Attribute)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(New)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Me)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(As)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(ByVal|ByRef|Optional|ParamArray)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Type|Enum|End\\s+Type|End\\s+Enum)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(RaiseEvent|Event|WithEvents)\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Declare\\s+(Sub|Function|PtrSafe\\s+Sub|PtrSafe\\s+Function))\\b"
        },
        {
          "name": "keyword.other.vba",
          "match": "(?i)\\b(Lib|Alias)\\b"
        }
      ]
    },
    "storage-modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.vba",
          "match": "(?i)\\b(Dim|ReDim|ReDim\\s+Preserve|Public|Private|Static|Const|Global|Friend)\\b"
        }
      ]
    },
    "data-types": {
      "patterns": [
        {
          "name": "storage.type.vba",
          "match": "(?i)\\b(String|Integer|Long|Single|Double|Currency|Date|Boolean|Byte|Variant|Object|LongPtr|LongLong|Decimal|Any)\\b"
        }
      ]
    },
    "procedure-declaration": {
      "patterns": [
        {
          "name": "meta.function.vba",
          "match": "(?i)^\\s*(?:(Public|Private|Friend)\\s+)?(?:(Static)\\s+)?(Sub|Function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.vba" },
            "2": { "name": "storage.modifier.vba" },
            "3": { "name": "storage.type.function.vba" },
            "4": { "name": "entity.name.function.vba" }
          }
        }
      ]
    },
    "property-declaration": {
      "patterns": [
        {
          "name": "meta.property.vba",
          "match": "(?i)^\\s*(?:(Public|Private|Friend)\\s+)?(?:(Static)\\s+)?Property\\s+(Get|Let|Set)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.vba" },
            "2": { "name": "storage.modifier.vba" },
            "3": { "name": "storage.type.property.vba" },
            "4": { "name": "entity.name.function.vba" }
          }
        }
      ]
    },
    "variable-declaration": {
      "patterns": [
        {
          "name": "meta.variable.vba",
          "match": "(?i)\\b(Dim|Private|Public|Static|Global)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.vba" },
            "2": { "name": "variable.other.vba" }
          }
        },
        {
          "name": "meta.variable.const.vba",
          "match": "(?i)\\b(?:(Public|Private)\\s+)?(Const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.vba" },
            "2": { "name": "storage.modifier.vba" },
            "3": { "name": "variable.other.constant.vba" }
          }
        },
        {
          "name": "meta.variable.redim.vba",
          "match": "(?i)\\b(ReDim)(?:\\s+(Preserve))?\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.vba" },
            "2": { "name": "storage.modifier.vba" },
            "3": { "name": "variable.other.vba" }
          }
        }
      ]
    },
    "option-statements": {
      "patterns": [
        {
          "name": "keyword.other.option.vba",
          "match": "(?i)^\\s*Option\\s+(Explicit|Compare\\s+(Text|Binary|Database)|Base\\s+[01]|Private\\s+Module)"
        }
      ]
    },
    "on-error": {
      "patterns": [
        {
          "name": "keyword.control.error.vba",
          "match": "(?i)\\bOn\\s+Error\\s+(GoTo|Resume\\s+Next|GoTo\\s+0|GoTo\\s+[A-Za-z_][A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.vba",
          "match": "(?i)^\\s*(#If|#ElseIf)\\b(.*)\\b(Then)\\b",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.vba" },
            "3": { "name": "keyword.control.preprocessor.vba" }
          }
        },
        {
          "name": "meta.preprocessor.vba",
          "match": "(?i)^\\s*(#Else|#End\\s+If)\\b",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.vba" }
          }
        },
        {
          "name": "meta.preprocessor.vba",
          "match": "(?i)^\\s*(#Const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.vba" },
            "2": { "name": "variable.other.constant.preprocessor.vba" }
          }
        }
      ]
    }
  }
}
